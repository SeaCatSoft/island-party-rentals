rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: anyone can read (the store needs them),
    // only signed-in staff can create/edit/delete.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: customers can create orders and the store can read
    // them to work out availability. Only signed-in staff can
    // update (change status) or delete.
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(
          ['ref','items','date','timeSlot','customer','subtotal','deposit','paymentMethod','status','createdAt'])
        && request.resource.data.status == 'pending-deposit';
      allow update, delete: if request.auth != null;
    }
  }
}
